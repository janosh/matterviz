{
  "compilerOptions": {
    "target": "esnext",
    "module": "ESNext",
    "noEmit": true,
    "rootDir": "../..",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "types": ["node"],
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "paths": {
      "$lib": ["../../src/lib"],
      "$lib/*": ["../../src/lib/*"]
    }
  },
  "include": ["src/**/*", "tests/**/*"]
}
