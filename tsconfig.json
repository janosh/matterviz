{
  "extends": "./.svelte-kit/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "module": "esnext",
    "target": "esnext",
    "moduleResolution": "bundler",
    // To have warnings/errors of the Svelte compiler at the correct position,
    // enable source maps by default.
    "sourceMap": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    // allow importing @wooorm/starry-night/style/both.css (types via its .d.css.ts) from +layout.svelte
    "allowArbitraryExtensions": true,
    "skipLibCheck": true
  },
  // anywidget-renderers.test.ts imports the built `matterviz` package (dist) via
  // anywidget.ts; svelte-check would then resolve dist alongside src, creating a
  // duplicate Svelte `Snippet` identity that cascades false errors across src/lib.
  // vi.mock handles the import at runtime (vitest still runs the file), so excluding
  // it from type-checking is safe.
  "exclude": ["src/scripts", "extensions", "tests/vitest/anywidget-renderers.test.ts"]
}
